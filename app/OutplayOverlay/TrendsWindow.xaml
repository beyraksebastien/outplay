<Window x:Class="OutplayOverlay.TrendsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Trends"
        Width="640" SizeToContent="Height"
        MaxHeight="800"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="NoResize">

    <Border Background="#EE101010" BorderBrush="#444" BorderThickness="1" CornerRadius="8" Padding="16">
        <StackPanel>
            <Grid Margin="0,0,0,4">
                <TextBlock x:Name="TitleText" Text="TRENDS — iRacing" Foreground="White" FontFamily="Consolas"
                           FontSize="14" FontWeight="Bold"/>
                <Button Content="x" Width="22" Height="22" HorizontalAlignment="Right" VerticalAlignment="Top"
                        Background="Transparent" BorderThickness="0" Foreground="Gray"
                        FontFamily="Consolas" Cursor="Hand" Click="CloseButton_Click"/>
            </Grid>

            <TextBlock Text="sim-wide · last 10 sessions · not per-track yet" Foreground="Gray"
                       FontFamily="Consolas" FontSize="11" Margin="0,0,0,10"/>

            <Border BorderBrush="#333" BorderThickness="0,0,0,1" Margin="0,0,0,10"/>

            <!-- Two-tab strip, only shown when both sims have history. -->
            <StackPanel x:Name="TabStrip" Orientation="Horizontal" Visibility="Collapsed" Margin="0,0,0,10">
                <Button x:Name="IRacingTabButton" Content="[ iRACING ]" FontFamily="Consolas" FontSize="11"
                        Background="Transparent" BorderThickness="0" Foreground="White" Cursor="Hand"
                        Margin="0,0,10,0" Click="IRacingTabButton_Click"/>
                <Button x:Name="F125TabButton" Content="[ F1 25 ]" FontFamily="Consolas" FontSize="11"
                        Background="Transparent" BorderThickness="0" Foreground="Gray" Cursor="Hand"
                        Click="F125TabButton_Click"/>
            </StackPanel>

            <!-- Empty state: no history yet for the selected/only sim. -->
            <TextBlock x:Name="EmptyStateText" Text="No session history yet." Foreground="Gray"
                       FontFamily="Consolas" FontSize="12" HorizontalAlignment="Center"
                       TextWrapping="Wrap" Margin="0,20,0,20" Visibility="Collapsed"/>

            <StackPanel x:Name="ContentPanel">
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="SESSIONS" Foreground="Gray" FontFamily="Consolas" FontSize="10"/>
                        <TextBlock x:Name="SessionsText" Text="--" Foreground="White" FontFamily="Consolas" FontSize="16" FontWeight="Bold"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="LAPS" Foreground="Gray" FontFamily="Consolas" FontSize="10"/>
                        <TextBlock x:Name="LapsText" Text="--" Foreground="White" FontFamily="Consolas" FontSize="16" FontWeight="Bold"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="BEST LAP EVER" Foreground="Gray" FontFamily="Consolas" FontSize="10"/>
                        <TextBlock x:Name="BestLapEverText" Text="--" Foreground="LimeGreen" FontFamily="Consolas" FontSize="16" FontWeight="Bold"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3">
                        <TextBlock Text="SINCE FIRST" Foreground="Gray" FontFamily="Consolas" FontSize="10"/>
                        <TextBlock x:Name="SinceFirstText" Text="--" Foreground="White" FontFamily="Consolas" FontSize="16" FontWeight="Bold"/>
                    </StackPanel>
                </Grid>

                <Border BorderBrush="#333" BorderThickness="0,0,0,1" Margin="0,0,0,10"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="RECENT TREND: " Foreground="Gray" FontFamily="Consolas" FontSize="11"/>
                    <TextBlock x:Name="RecentTrendText" Text="--" Foreground="Gray" FontFamily="Consolas" FontSize="11" FontWeight="Bold"/>
                    <TextBlock Text="   (last 10 sessions)" Foreground="Gray" FontFamily="Consolas" FontSize="11"/>
                </StackPanel>

                <Border BorderBrush="#333" BorderThickness="0,0,0,1" Margin="0,0,0,10"/>

                <TextBlock Text="SESSION BESTS (oldest → newest)" Foreground="Gray" FontFamily="Consolas"
                           FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>

                <ScrollViewer MaxHeight="360" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="SessionBarsPanel"/>
                </ScrollViewer>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                <Button Content="Close" FontFamily="Consolas" FontSize="11"
                        Padding="10,4" Click="CloseButton_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
