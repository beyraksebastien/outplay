<Window x:Class="OutplayOverlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Outplay Overlay"
        Width="260" Height="300"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Left="20" Top="20"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border Background="#CC101010" CornerRadius="8" Padding="12">
        <Grid>
            <StackPanel>
            <!-- Coaching block: shown before the "COACH: (none)" fallback until the first
                 CoachingSignal arrives, then swaps to the live state/delta/gap/tires rows. -->
            <TextBlock x:Name="CoachNoSignalText" Text="COACH: --" Foreground="Gray"
                       FontFamily="Consolas" FontSize="12" Margin="0,0,0,8"/>

            <StackPanel x:Name="CoachPanel" Visibility="Collapsed" Margin="0,0,0,8">
                <TextBlock x:Name="CoachStateText" Text="STEADY" Foreground="White"
                           FontFamily="Consolas" FontSize="28" FontWeight="Bold"/>

                <Grid Margin="0,2,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="Δ best: " Foreground="Gray" FontFamily="Consolas" FontSize="11"/>
                        <TextBlock x:Name="CoachDeltaText" Text="--" Foreground="Gray" FontFamily="Consolas" FontSize="11"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <TextBlock Text="gap ahead: " Foreground="Gray" FontFamily="Consolas" FontSize="11"/>
                        <TextBlock x:Name="CoachGapText" Text="--" Foreground="White" FontFamily="Consolas" FontSize="11"/>
                    </StackPanel>
                </Grid>

                <TextBlock x:Name="CoachTiresText" Text="YOU -- · AHEAD --" Foreground="Gray"
                           FontFamily="Consolas" FontSize="10" Margin="0,2,0,0"/>
            </StackPanel>

            <Border BorderBrush="#333" BorderThickness="0,0,0,1" Margin="0,0,0,8"/>

            <TextBlock x:Name="StatusText" Text="Waiting for sim..." Foreground="Orange"
                       FontFamily="Consolas" FontSize="12" Margin="0,0,0,8"/>

            <!-- Debrief notification pill: hidden until SessionLogger.SummaryReady fires
                 (see MainWindow.xaml.cs OnSummaryReady). Persists until clicked or superseded
                 by a newer summary - no auto-hide timer. -->
            <Border x:Name="DebriefPill" Visibility="Collapsed" Background="#33101010"
                    BorderBrush="#444" BorderThickness="1" CornerRadius="10" Padding="8,4"
                    Margin="0,0,0,8" Cursor="Hand" MouseLeftButtonUp="DebriefPill_Click">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Fill="LimeGreen" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="Debrief ready" Foreground="Gray" FontFamily="Consolas" FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock Text="  View" Foreground="White" FontFamily="Consolas" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <TextBlock Text="SPEED" Foreground="Gray" FontFamily="Consolas" FontSize="10"/>
            <TextBlock x:Name="SpeedText" Text="0 km/h" Foreground="White" FontFamily="Consolas" FontSize="20" Margin="0,0,0,8"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                    <TextBlock Text="THROTTLE" Foreground="Gray" FontFamily="Consolas" FontSize="10"/>
                    <ProgressBar x:Name="ThrottleBar" Height="14" Minimum="0" Maximum="1" Foreground="LimeGreen" Background="#333"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="BRAKE" Foreground="Gray" FontFamily="Consolas" FontSize="10"/>
                    <ProgressBar x:Name="BrakeBar" Height="14" Minimum="0" Maximum="1" Foreground="OrangeRed" Background="#333"/>
                </StackPanel>
            </Grid>

            <TextBlock Text="STEERING" Foreground="Gray" FontFamily="Consolas" FontSize="10" Margin="0,8,0,0"/>
            <ProgressBar x:Name="SteeringBar" Height="14" Minimum="-1" Maximum="1" Foreground="DeepSkyBlue" Background="#333"/>

            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="GEAR" Foreground="Gray" FontFamily="Consolas" FontSize="10"/>
                <TextBlock x:Name="GearText" Grid.Column="1" Text="-" Foreground="White" FontFamily="Consolas" FontSize="14" HorizontalAlignment="Right"/>
            </Grid>
            </StackPanel>

            <!-- Trends: opens the cross-session TrendsWindow. -->
            <Button x:Name="TrendsButton" Content="📈" HorizontalAlignment="Right" VerticalAlignment="Top"
                    Width="20" Height="20" Padding="0" FontSize="12" Margin="0,0,0,0"
                    Background="Transparent" BorderThickness="0" Foreground="Gray"
                    Cursor="Hand" Click="TrendsButton_Click"/>
        </Grid>
    </Border>
</Window>
