<Window x:Class="OutplayOverlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Outplay Overlay"
        Width="260" Height="220"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Left="20" Top="20"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border Background="#CC101010" CornerRadius="8" Padding="12">
        <StackPanel>
            <TextBlock x:Name="StatusText" Text="Waiting for sim..." Foreground="Orange"
                       FontFamily="Consolas" FontSize="12" Margin="0,0,0,8"/>

            <TextBlock Text="SPEED" Foreground="Gray" FontFamily="Consolas" FontSize="10"/>
            <TextBlock x:Name="SpeedText" Text="0 km/h" Foreground="White" FontFamily="Consolas" FontSize="20" Margin="0,0,0,8"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                    <TextBlock Text="THROTTLE" Foreground="Gray" FontFamily="Consolas" FontSize="10"/>
                    <ProgressBar x:Name="ThrottleBar" Height="14" Minimum="0" Maximum="1" Foreground="LimeGreen" Background="#333"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="BRAKE" Foreground="Gray" FontFamily="Consolas" FontSize="10"/>
                    <ProgressBar x:Name="BrakeBar" Height="14" Minimum="0" Maximum="1" Foreground="OrangeRed" Background="#333"/>
                </StackPanel>
            </Grid>

            <TextBlock Text="STEERING" Foreground="Gray" FontFamily="Consolas" FontSize="10" Margin="0,8,0,0"/>
            <ProgressBar x:Name="SteeringBar" Height="14" Minimum="-1" Maximum="1" Foreground="DeepSkyBlue" Background="#333"/>

            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="GEAR" Foreground="Gray" FontFamily="Consolas" FontSize="10"/>
                <TextBlock x:Name="GearText" Grid.Column="1" Text="-" Foreground="White" FontFamily="Consolas" FontSize="14" HorizontalAlignment="Right"/>
            </Grid>
        </StackPanel>
    </Border>
</Window>
